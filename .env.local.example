# ─── Supabase ────────────────────────────────────────────────────────────────
# Found at: https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Keep this SECRET — server-side only

# ─── NextAuth (if used alongside Supabase) ───────────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ─── SMS / OTP Provider (Termii — Nigerian SMS gateway) ──────────────────────
# Sign up at https://termii.com
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=N-Alert

# ─── App config ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
